# Sanity (leave unset to run the site with sample placeholder artwork)
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Web3Forms (leave unset to fall back to a mailto: link)
PUBLIC_WEB3FORMS_KEY=
PUBLIC_CONTACT_EMAIL=hello@example.com

# Sentry error tracking (leave unset to skip entirely — no Sentry code ships)
# DSN comes from your Sentry project settings → Client Keys (DSN).
PUBLIC_SENTRY_DSN=

# Umami analytics (leave unset to skip entirely)
# PUBLIC_UMAMI_SRC is the full tracker script URL — use your self-hosted
# instance (e.g. https://umami.yourdomain.com/script.js) or Umami Cloud
# (https://cloud.umami.is/script.js). PUBLIC_UMAMI_WEBSITE_ID comes from
# the tracking snippet on your Umami website settings page. Neither value
# is a secret — both end up in publicly visible page HTML.
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=
