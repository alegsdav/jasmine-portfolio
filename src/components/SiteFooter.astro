---
import { socials } from "../lib/socials";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__left">
    <img class="site-footer__logo" src="/jamstain.png" alt="Jamstain" />
    <div class="site-footer__links">
      <button type="button" class="contact-trigger" data-open-contact>Contact</button>
      <ul class="site-footer__socials">
        {
          socials.map((social) => (
            <li>
              <a href={social.href} aria-label={social.label} target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                  <path d={social.path} />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <span class="site-footer__mark">&copy; {year} Jamstain</span>
  </div>

  <img
    class="site-footer__cat"
    src="/blackcat.webp"
    width="900"
    height="790"
    alt="A curious cat peeking into the corner"
    aria-hidden="true"
    loading="lazy"
    decoding="async"
  />
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    min-height: 340px;
    color: var(--ink-soft);
  }

  .site-footer__logo {
    width: clamp(300px, 48vw, 560px);
    height: auto;
    margin-bottom: 1.25rem;
    user-select: none;
    -webkit-user-drag: none;
  }

  .site-footer__left {
    position: absolute;
    left: 2.5rem;
    bottom: 2rem;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .site-footer__links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    min-height: 1.25rem;
  }

  .contact-trigger {
    background: none;
    border: none;
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: none;
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
    height: 18px;
    transition: opacity 0.2s ease;
  }

  .site-footer__socials {
    display: flex;
    align-items: center;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
    height: 18px;
  }

  .site-footer__socials li {
    display: flex;
    align-items: center;
  }

  .site-footer__socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    line-height: 0;
  }

  .site-footer__socials svg {
    display: block;
  }

  .contact-trigger:hover {
    opacity: 0.6;
  }

  .site-footer__mark {
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: none;
  }

  .site-footer__cat {
    position: absolute;
    right: 0;
    bottom: 0;
    width: clamp(220px, 30vw, 360px);
    height: auto;
    z-index: 0;
    user-select: none;
    -webkit-user-drag: none;
    pointer-events: none;
  }

  @media (max-width: 720px) {
    .site-footer {
      min-height: 280px;
    }

    .site-footer__logo {
      width: min(75vw, 380px);
    }

    .site-footer__left {
      left: 1.25rem;
      bottom: 1.5rem;
    }

    .site-footer__cat {
      width: clamp(160px, 44vw, 240px);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-open-contact]").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("open-contact-modal"));
    });
  });
</script>
