---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__left">
    <img class="site-footer__logo" src="/jamstain.png" alt="Jamstain" />
    <button type="button" class="contact-trigger" data-open-contact>Contact</button>
    <span class="site-footer__mark">&copy; {year} Jamstain</span>
  </div>

  <img
    class="site-footer__cat"
    src="/businesscat.png"
    alt="A curious cat peeking into the corner"
    aria-hidden="true"
  />
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    min-height: 340px;
    color: var(--ink-soft);
  }

  .site-footer__logo {
    width: clamp(300px, 48vw, 560px);
    height: auto;
    margin-bottom: 1.25rem;
    user-select: none;
    -webkit-user-drag: none;
  }

  .site-footer__left {
    position: absolute;
    left: 2.5rem;
    bottom: 2rem;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-trigger {
    background: none;
    border: none;
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: none;
    cursor: pointer;
    padding: 0;
    align-self: flex-start;
    transition: opacity 0.2s ease;
  }

  .contact-trigger:hover {
    opacity: 0.6;
  }

  .site-footer__mark {
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: none;
  }

  .site-footer__cat {
    position: absolute;
    right: 0;
    bottom: 0;
    width: clamp(220px, 30vw, 360px);
    height: auto;
    z-index: 0;
    user-select: none;
    -webkit-user-drag: none;
    pointer-events: none;
  }

  @media (max-width: 720px) {
    .site-footer {
      min-height: 280px;
    }

    .site-footer__logo {
      width: min(75vw, 380px);
    }

    .site-footer__left {
      left: 1.25rem;
      bottom: 1.5rem;
    }

    .site-footer__cat {
      width: clamp(160px, 44vw, 240px);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-open-contact]").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("open-contact-modal"));
    });
  });
</script>
