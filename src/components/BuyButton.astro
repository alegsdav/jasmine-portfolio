---
import type { Product } from "../lib/types";

interface Props {
  product: Product;
}

const { product } = Astro.props;

const formattedPrice = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: product.currency || "USD",
  maximumFractionDigits: 0,
}).format(product.price);
---

<p class="price-tag">{formattedPrice}</p>

{
  product.status === "sold-out" ? (
    <button class="buy-button buy-button--disabled" disabled>
      Sold out
    </button>
  ) : product.buyLink ? (
    <a
      class="buy-button"
      href={product.buyLink}
      target="_blank"
      rel="noopener noreferrer"
      data-umami-event="buy-click"
      data-umami-event-product={product.title}
      data-umami-event-price={product.price ?? ""}
    >
      Buy now
    </a>
  ) : (
    <>
      <button class="buy-button buy-button--disabled" disabled>
        Purchase coming soon
      </button>
      <p class="buy-note">Interested now? Use the contact form to inquire.</p>
    </>
  )
}
