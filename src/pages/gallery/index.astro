---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorksHeader from "../../components/WorksHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import ContactModal from "../../components/ContactModal.astro";
import Lightbox from "../../components/Lightbox.astro";
import ArtworkCard from "../../components/ArtworkCard.astro";
import { getAllArtworks, isSanityConfigured, urlForImage, srcSetForImage } from "../../lib/sanity";

const artworks = await getAllArtworks();
const MODAL_WIDTHS = [640, 960, 1280, 1600, 2000];
const modalArtworks = artworks.map((artwork) => ({
  slug: artwork.slug,
  title: artwork.title,
  year: artwork.year,
  medium: artwork.medium,
  dimensions: artwork.dimensions,
  description: artwork.description,
  imageSrc: urlForImage(artwork.image.url, 2000, 85),
  imageSrcSet: srcSetForImage(artwork.image.url, MODAL_WIDTHS, 85) || undefined,
  imageAlt: artwork.image.alt,
  imageWidth: artwork.image.width,
  imageHeight: artwork.image.height,
}));
---

<BaseLayout title="Gallery | Jamstain" description="Selected works — drawings and studies by Jamstain.">
  <WorksHeader />

  <main class="works-main">
    <section class="works-section">
      <h1 class="oeuvre-title">Gallery</h1>

      {
        !isSanityConfigured && (
          <p style="color:#a33; font-size:0.85rem; margin:-2rem 0 2rem;">
            Showing sample placeholder pieces — connect Sanity to manage real artwork (see README).
          </p>
        )
      }

      <div class="oeuvre-gallery">
        {artworks.map((artwork) => <ArtworkCard artwork={artwork} />)}
      </div>
    </section>
  </main>

  <SiteFooter />
  <Lightbox artworks={modalArtworks} />
  <ContactModal />
</BaseLayout>
