---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorksHeader from "../../components/WorksHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import ContactModal from "../../components/ContactModal.astro";
import { getAllArtworks, urlForImage, srcSetForImage } from "../../lib/sanity";
import type { Artwork } from "../../lib/types";

export async function getStaticPaths() {
  const artworks = await getAllArtworks();
  return artworks.map((artwork) => ({
    params: { slug: artwork.slug },
    props: { artwork },
  }));
}

interface Props {
  artwork: Artwork;
}

const { artwork } = Astro.props;

const DETAIL_WIDTHS = [640, 960, 1280, 1600, 2000];
const detailSrc = urlForImage(artwork.image.url, 1280);
const detailSrcSet = srcSetForImage(artwork.image.url, DETAIL_WIDTHS, 85) || undefined;
const socialImage = urlForImage(artwork.image.url, 1200, 80);
---

<BaseLayout
  title={`${artwork.title} | Jamstain`}
  description={artwork.description || `${artwork.title} by Jamstain.`}
  image={socialImage}
>
  <WorksHeader />

  <main class="works-main">
    <section class="works-section">
      <a href="/gallery/" class="artwork__back">Back to gallery</a>

      <div class="artwork">
        <div class="artwork__frame">
          <img
            src={detailSrc}
            srcset={detailSrcSet}
            sizes="(max-width: 860px) 100vw, 60vw"
            width={artwork.image.width}
            height={artwork.image.height}
            alt={artwork.image.alt}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>

        <div>
          <h1 class="artwork__title">{artwork.title}</h1>
          <p class="artwork__meta">
            {artwork.medium && <span>{artwork.medium}</span>}
            {artwork.dimensions && <span>{artwork.dimensions}</span>}
            {artwork.year && <span>{artwork.year}</span>}
          </p>
          {artwork.description && <p class="artwork__description">{artwork.description}</p>}
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
  <ContactModal />
</BaseLayout>
