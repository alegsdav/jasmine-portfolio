---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorksHeader from "../components/WorksHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ContactModal from "../components/ContactModal.astro";
import { socials } from "../lib/socials";
---

<BaseLayout title="About | Jamstain" description="About Jamstain — artist and illustrator.">
  <WorksHeader />

  <main class="about-main">
    <section class="about">
      <img class="about__image" src="/IMG_5388.webp" alt="Portrait of Jamstain" />

      <div class="about__content">
        
        <h1 class="about__title">About Me</h1>
        

        <div class="about__body">
          <p>
            Jasmine Wu is a 20-year-old digital artist and content creator based in the Bay Area. Her passion for art began at a young age, sparked by countless doodles she created in her free time. As she continued taking art classes throughout her childhood, she developed a strong foundation in color theory, composition, and traditional media, exploring techniques in charcoal, watercolor, acrylic, and graphite.
          </p>
          <p>
            Growing up, Jasmine also found inspiration in creative video games such as Animal Jam and Minecraft, which fueled her interest in digital illustration. This passion led her to refine her skills using industry-standard tools like Procreate and Adobe Photoshop, where she specializes in creating vibrant, expressive artwork.
          </p>
          <p>
            Jasmine is currently pursuing a degree in Business Entrepreneurship at Las Positas College, combining her artistic background with the business knowledge needed to build a successful freelance creative career. She enjoys creating custom commissions, sharing her creative process online, and mentoring aspiring artists who are beginning their own artistic journeys.
          </p>
          <p>
            If you'd like to commission artwork, collaborate on a project, or simply connect, feel free to reach out through the <button type="button" data-open-contact>Contact page</button>. Jasmine would love to hear from you!
          </p>
        </div>

        <ul class="about__socials">
          {
            socials.map((social) => (
              <li>
                <a href={social.href} aria-label={social.label} target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                    <path d={social.path} />
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>

  <SiteFooter />
  <ContactModal />
</BaseLayout>

<style>
  .about-main {
    min-height: calc(100dvh - 5rem);
  }

  .about {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: start;
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2.5rem 6rem;
  }

  .about__image {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
    background: var(--rule);
    border: 1px solid #e0e0e0;
  }

  .about__title {
    font-family: "ReenieBeanie", cursive;
    font-style: normal;
    font-weight: 400;
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 1;
    margin: 0 0 1rem;
    letter-spacing: 0.02em;
  }

  .about__subtitle {
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1.75rem;
  }

  .about__body {
    color: var(--ink-soft);
    max-width: 52ch;
  }

  .about__body p {
    margin: 0 0 1.25rem;
  }

  .about__body button[data-open-contact] {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: inherit;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 0.15em;
    transition: opacity 0.2s ease;
  }

  .about__body button[data-open-contact]:hover {
    opacity: 0.6;
  }

  .about__socials {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
  }

  .about__socials a {
    display: inline-flex;
    color: var(--ink);
  }

  @media (max-width: 860px) {
    .about {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 3rem 1.25rem 5rem;
    }

    .about__image {
      max-width: 360px;
    }
  }
</style>
